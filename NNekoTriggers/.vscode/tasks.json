{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Plugin",
      "type": "shell",
      "command": "dotnet build NNekoTriggers.csproj --configuration Release",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Copy to devPlugins",
      "type": "shell",
      "dependsOn": "Build Plugin",
      "command": "powershell -Command \"Copy-Item -Recurse -Force ./bin/Release/* $env:APPDATA/Dalamud/devPlugins/NNekoTriggers\""
    }
  ]
}
